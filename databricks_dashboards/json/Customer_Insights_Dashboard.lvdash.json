{
  "datasets": [
    {
      "name": "ba3bba31",
      "displayName": "customer_insights_dataset",
      "queryLines": [
        "WITH base_query AS (\r\n",
        "\r\n",
        "-- 1) Base Data\r\n",
        "SELECT\r\n",
        "    f.order_number,\r\n",
        "    f.product_key,\r\n",
        "    f.order_date,\r\n",
        "    f.sales_amount,\r\n",
        "    f.quantity,\r\n",
        "    c.customer_key,\r\n",
        "    c.customer_number,\r\n",
        "    CONCAT(c.first_name, ' ', c.last_name) AS customer_name,\r\n",
        "    c.birthdate,\r\n",
        "    \r\n",
        "    -- ✅ Correct Age Calculation\r\n",
        "    FLOOR(DATEDIFF(current_date(), c.birthdate) / 365) AS age\r\n",
        "\r\n",
        "FROM gold.fact_sales f\r\n",
        "LEFT JOIN gold.dim_customers c\r\n",
        "ON f.customer_key = c.customer_key\r\n",
        "\r\n",
        "WHERE f.order_date IS NOT NULL\r\n",
        "),\r\n",
        "\r\n",
        "customer_aggregation AS (\r\n",
        "\r\n",
        "-- 2) Customer Level Aggregation\r\n",
        "SELECT \r\n",
        "    customer_key,\r\n",
        "    customer_number,\r\n",
        "    customer_name,\r\n",
        "    age,\r\n",
        "\r\n",
        "    COUNT(DISTINCT order_number) AS total_orders,\r\n",
        "    SUM(sales_amount) AS total_sales,\r\n",
        "    SUM(quantity) AS total_quantity,\r\n",
        "    COUNT(DISTINCT product_key) AS total_products,\r\n",
        "\r\n",
        "    MAX(order_date) AS last_order_date,\r\n",
        "\r\n",
        "    -- ✅ Lifespan in months\r\n",
        "    FLOOR(DATEDIFF(MAX(order_date), MIN(order_date)) / 30) AS lifespan\r\n",
        "\r\n",
        "FROM base_query\r\n",
        "\r\n",
        "GROUP BY\r\n",
        "    customer_key,\r\n",
        "    customer_number,\r\n",
        "    customer_name,\r\n",
        "    age\r\n",
        ")\r\n",
        "\r\n",
        "-- 3) Final Output (Dashboard Ready)\r\n",
        "SELECT\r\n",
        "    customer_key,\r\n",
        "    customer_number,\r\n",
        "    customer_name,\r\n",
        "    age,\r\n",
        "\r\n",
        "    -- ✅ Age Group\r\n",
        "    CASE \r\n",
        "        WHEN age < 20 THEN 'Under 20'\r\n",
        "        WHEN age BETWEEN 20 AND 29 THEN '20-29'\r\n",
        "        WHEN age BETWEEN 30 AND 39 THEN '30-39'\r\n",
        "        WHEN age BETWEEN 40 AND 49 THEN '40-49'\r\n",
        "        ELSE '50 and above'\r\n",
        "    END AS age_group,\r\n",
        "\r\n",
        "    -- ✅ Customer Segment\r\n",
        "    CASE \r\n",
        "        WHEN lifespan >= 12 AND total_sales > 5000 THEN 'VIP'\r\n",
        "        WHEN lifespan >= 12 AND total_sales <= 5000 THEN 'Regular'\r\n",
        "        ELSE 'New'\r\n",
        "    END AS customer_segment,\r\n",
        "\r\n",
        "    last_order_date,\r\n",
        "\r\n",
        "    -- ✅ Recency (months)\r\n",
        "    FLOOR(DATEDIFF(current_date(), last_order_date) / 30) AS recency,\r\n",
        "\r\n",
        "    total_orders,\r\n",
        "    total_sales,\r\n",
        "    total_quantity,\r\n",
        "    total_products,\r\n",
        "    lifespan,\r\n",
        "\r\n",
        "    -- ✅ Avg Sales per Order\r\n",
        "    CASE \r\n",
        "        WHEN total_orders = 0 THEN 0\r\n",
        "        ELSE total_sales / total_orders\r\n",
        "    END AS avg_order_value,\r\n",
        "\r\n",
        "    -- ✅ Avg Monthly Spend\r\n",
        "    CASE \r\n",
        "        WHEN lifespan = 0 THEN total_sales\r\n",
        "        ELSE total_sales / lifespan\r\n",
        "    END AS avg_monthly_spend\r\n",
        "\r\n",
        "FROM customer_aggregation;"
      ]
    }
  ],
